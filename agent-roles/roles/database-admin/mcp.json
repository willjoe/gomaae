{
  "version": "1.0",
  "servers": {
    "ticket-system": {
      "command": "node",
      "args": [
        "/connectors/ticket-mcp-server.js"
      ],
      "env": {
        "ROLE_ID": "database-admin"
      }
    },
    "git-provider": {
      "command": "node",
      "args": [
        "/connectors/git-mcp-server.js"
      ]
    }
  },
  "capabilities": {
    "read_tickets": true,
    "update_ticket_status": true,
    "create_pr": true
  }
}