{
  "version": "1.0.0",
  "identity": {
    "name": "Database Admin",
    "id": "database-admin",
    "category": "Data & Machine Learning",
    "description": "Specializes in database schema design, migrations, indexing, and query optimization."
  },
  "sandbox_parameters": {
    "network_egress": "restricted",
    "allowed_domains": [
      "docs.python.org",
      "npmjs.com",
      "github.com"
    ],
    "default_container": "api-key-container",
    "max_execution_time_minutes": 60
  },
  "access_scopes": {
    "allowed_repositories": [],
    "vcs_attribution": {
      "GIT_AUTHOR_NAME": "AI-DATABASE-ADMIN",
      "GIT_COMMITTER_NAME": "AI-DATABASE-ADMIN"
    }
  }
}