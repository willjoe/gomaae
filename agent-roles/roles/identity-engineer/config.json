{
  "version": "1.0.0",
  "identity": {
    "name": "Identity Engineer",
    "id": "identity-engineer",
    "category": "Core Engineering",
    "description": "Centralizes the creation and management of all secrets, ephemeral credentials, API keys, and public-facing user identities."
  },
  "sandbox_parameters": {
    "network_egress": "restricted",
    "allowed_domains": [
      "docs.python.org",
      "npmjs.com",
      "github.com"
    ],
    "default_container": "api-key-container",
    "max_execution_time_minutes": 60
  },
  "access_scopes": {
    "allowed_repositories": [],
    "vcs_attribution": {
      "GIT_AUTHOR_NAME": "AI-IDENTITY-ENGINEER",
      "GIT_COMMITTER_NAME": "AI-IDENTITY-ENGINEER"
    }
  }
}