{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Gomaae",
  "version": "0.1.6",
  "identifier": "com.gomaae.app",
  "build": {
    "frontendDist": "frontend-shell",
    "devUrl": "http://localhost:4000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "node scripts/build-sidecar.mjs"
  },
  "app": {
    "windows": [
      {
        "title": "Gomaae",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlGN0Q1Q0FEMDlFRTFGODAKUldTQUgrNEpyVng5bjVkUThIVGJmeHNuRGMvdjBTVlpEWklzeWFDQ2ZOa0UvUkoyZjNGa1B2eUsK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/node"],
    "resources": ["sidecar-dist/**/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
